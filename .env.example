# Copiez ce fichier en `.env` et renseignez vos valeurs.

# Clé API Groq (gratuit sur console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port du serveur (3000 par défaut)
PORT=3000

# Secret JWT — changez-le avec une chaîne aléatoire longue
JWT_SECRET=change-me-with-a-long-random-secret-string
